def verify_model(model_path, model_name):
    """Verify ONNX model with actual inference"""
    if not os.path.exists(model_path):
        return False, "File not found"
    
    try:
        # Load model
        session = onnxruntime.InferenceSession(model_path)
        
        # Get input info
        input_name = session.get_inputs()[0].name
        input_shape = session.get_inputs()[0].shape
        
        # Create appropriate dummy input
        if len(input_shape) == 4:  # 2D CNN
            dummy = np.random.randn(1, 3, 224, 224).astype(np.float32)
        elif len(input_shape) == 3:  # 1D CNN
            dummy = np.random.randn(1, 12, 1000).astype(np.float32)
        else:
            dummy = np.random.randn(1, 128).astype(np.float32)
        
        # Run inference
        outputs = session.run(None, {input_name: dummy})
        
        # Check output shape
        output_shape = outputs[0].shape
        
        return True, f"Output shape: {output_shape}"
    except Exception as e:
        return False, str(e)[:100]

